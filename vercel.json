{
  "buildCommand": "pnpm --filter @workspace/sunglim build",
  "outputDirectory": "artifacts/sunglim/dist/public",
  "installCommand": "pnpm install",
  "functions": {
    "api/contact.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/contact", "destination": "/api/contact" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
